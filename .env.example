# ─────────────────────────────────────────────────────────────────────────────
# Пример переменных окружения для API-сервера «Барометр».
# Скопируй в .env.local и заполни реальными значениями (.env.local в .gitignore).
# НИКОГДА не коммить .env.local с реальными секретами.
# Читается сервером scripts/dev-api-server.ts (PM2 на VPS) и запасным путём api/ (Vercel).
# ─────────────────────────────────────────────────────────────────────────────

# ── Авторизация (обязательно) ────────────────────────────────────────────────
# Логин/пароль проверяются ТОЛЬКО на сервере (эндпоинт /api/auth).
APP_LOGIN=your-login
APP_PASSWORD=your-password
# Секрет для HMAC-SHA256 подписи сессионных токенов (signToken/verifyToken).
# Длинная случайная строка. При смене — все выданные токены инвалидируются.
APP_SESSION_SECRET=change-me-to-a-long-random-string

# ── Anthropic (обязательно для ИИ-чата) ──────────────────────────────────────
# Ключ Anthropic API (эндпоинт /api/chat). Без него /api/chat вернёт 500.
ANTHROPIC_API_KEY=your-anthropic-api-key
# Опционально: базовый URL прокси для обхода блокировки РФ (Cloudflare Worker).
# ВАЖНО: суффикс /anthropic обязателен — Worker его стрипает и форвардит на api.anthropic.com.
# Если не задан — SDK бьёт напрямую в api.anthropic.com (годится для Vercel вне РФ).
ANTHROPIC_PROXY_URL=https://anthropic-proxy.example.workers.dev/anthropic

# ── Веб-поиск Brave (опционально) ────────────────────────────────────────────
# Ключ Brave Search API (эндпоинт /api/search, инструмент search_web).
# Без него поиск возвращает пустой результат с пояснением (не падает).
BRAVE_SEARCH_API_KEY=your-brave-search-api-key
# Опционально: базовый URL прокси для Brave (тот же Worker, суффикс /brave).
# Если не задан — используется https://api.search.brave.com напрямую.
BRAVE_PROXY_URL=https://anthropic-proxy.example.workers.dev/brave

# ── Cloudflare Worker прокси (опционально) ────────────────────────────────────
# Секрет для доступа к Worker (заголовок x-proxy-secret). Нужен, только если
# используешь ANTHROPIC_PROXY_URL / BRAVE_PROXY_URL, указывающие на защищённый Worker.
PROXY_SECRET=your-proxy-secret

# ── Прочее (опционально) ──────────────────────────────────────────────────────
# Порт API-сервера. По умолчанию 3001 (dev-api-server), 3002 для npm start.
PORT=3001
