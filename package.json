{
  "name": "po-copilot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,vite -c blue,green \"tsx scripts/dev-api-server.ts\" \"vite\"",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
